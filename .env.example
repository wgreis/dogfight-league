# Copy these into Railway -> your service -> Variables (do NOT commit real values)

# GHIN login used for handicap lookups (same credentials you use in the GHIN mobile app)
GHIN_USERNAME=your_ghin_email_or_number
GHIN_PASSWORD=your_ghin_password

# Optional: protect the whole site with one shared password (browser will prompt).
# Leave unset to make the site open to anyone with the URL.
# LEAGUE_PASSWORD=ourleague2026

# Optional: where league data is stored. Defaults to /data (mount a Railway Volume there).
# DATA_DIR=/data
